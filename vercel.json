{
  "version": 2,
  "name": "trending-token-tracker",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "app/api/trending-tokens/route.ts": {
      "maxDuration": 30
    },
    "app/api/buy-token/route.ts": {
      "maxDuration": 30
    }
  }
}
